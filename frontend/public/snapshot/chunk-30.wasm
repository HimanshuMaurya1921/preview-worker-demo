{
  "name": "tailwindcss",
  "version": "3.4.19",
  "description": "A utility-first CSS framework for rapidly building custom user interfaces.",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "types/index.d.ts",
  "repository": {
    "type": "git",
