  for (var i in r) {

    //	console.log(r[i].toFraction());
  }

  var R = (vecSub(V, r));

  console.log("X" + j);
  console.log(R[0].toFraction(), "= " + R[0].valueOf());
  console.log(R[1].toFraction(), "= " + R[1].valueOf());
  console.log("\n");

