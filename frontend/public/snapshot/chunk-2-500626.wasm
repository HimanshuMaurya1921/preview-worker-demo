var Fraction = require('fraction.js');

var tab = [];
for (var d = 1; d <= 360; d++) {

   var pi = Fraction(2, 360).mul(d);
   var tau = Fraction(1, 360).mul(d);

   if (pi.d <= 6n && pi.d != 5n)
