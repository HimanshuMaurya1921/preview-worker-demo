# Runtime Mode: 'local' (Docker) or 'gke' (Kubernetes)
RUNTIME=local

# Auth token for secure communication between Orchestrator and Workers
# IMPORTANT: Generate a secure random string (e.g. openssl rand -base64 32)
WORKER_AUTH_TOKEN=local-dev-token

# Orchestrator Port
WORKER_PORT=3001

# Worker Image Name
# - Local: preview-worker:local
# - K8s:   gcr.io/YOUR_PROJECT/preview-worker:latest
WORKER_IMAGE=preview-worker:local

# Performance & Timeouts
BOOT_TIMEOUT_MS=90000
MAX_PREVIEW_PODS=40

# GKE Specific (ignored in local mode)
# KUBERNETES_SERVICE_HOST= (set automatically by K8s)
